# Configurações de Ambiente para Execução via PM2 / Host Local

# Backend (API Python)
PROJECT_NAME="SaaS Chatbot API"
SECRET_KEY="SUPER_SECRET_KEY_PRODUCAO_MUDAR_DEPOIS"
PYTHONPATH=.

# Banco de Dados (Docker containers expondo porta no localhost)
POSTGRES_SERVER=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=password123
POSTGRES_DB=saas_omnichannel

# NoSQL & Messaging (Docker containers expondo porta no localhost)
MONGODB_URL=mongodb://127.0.0.1:27017/SaaS_Chatbot
REDIS_URL=redis://127.0.0.1:6379/0
RABBITMQ_URL=amqp://admin:password123@127.0.0.1/

# WhatsApp Bridge (Node.js)
WHATSAPP_BRIDGE_URL=http://127.0.0.1:4000
BRIDGE_API_KEY=BOT_API_KEY_LOCAL

# Configurações do Bridge (Node.js)
PORT=4000
WEBHOOK_URL=http://127.0.0.1:8000/api/v1/gateway/webhook/whatsapp

