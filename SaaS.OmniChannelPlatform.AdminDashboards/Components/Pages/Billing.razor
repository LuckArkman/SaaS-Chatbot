@page "/billing"
@inject ApiService ApiService

@code {
    private BillingInfoModel? billingInfo;

    protected override async Task OnInitializedAsync()
    {
        billingInfo = await ApiService.GetBillingInfoAsync(Guid.Empty);
    }
}

<PageTitle>Faturamento | OmniSaaS</PageTitle>

<div class="animate-fade">
    <div style="margin-bottom: 2.5rem;">
        <h1 class="outfit" style="font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem;">Faturamento & Assinatura</h1>
        <p style="color: var(--text-muted);">Gerencie seus pagamentos e limites de uso.</p>
    </div>

    @if (billingInfo != null)
    {
        <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 1.5rem;">
            <div class="card" style="background: linear-gradient(135deg, var(--bg-card), var(--primary-glow));">
                <h3 class="outfit" style="margin-bottom: 2rem;">Plano Atual</h3>
                <div style="margin-bottom: 2rem;">
                    <h2 style="font-size: 2.5rem; font-weight: 800;" class="outfit">@billingInfo.PlanName</h2>
                    <p style="color: rgba(255,255,255,0.8);">R$ @billingInfo.Price.ToString("N2") / mês</p>
                </div>
                <ul style="list-style: none; margin-bottom: 2rem;">
                    <li style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; font-size: 0.9rem;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        @billingInfo.MessageLimit.ToString("N0") Mensagens / mês
                    </li>
                    <li style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; font-size: 0.9rem;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        @(billingInfo.PlanName == "Enterprise" ? "Chats Ilatados" : "5 Chats simultâneos")
                    </li>
                    <li style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; font-size: 0.9rem;">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        Suporte via E-mail
                    </li>
                </ul>
                <button class="btn-primary" style="width: 100%; background: white; color: var(--primary); justify-content: center;">Mudar de Plano</button>
            </div>

            <div class="card">
                <h3 class="outfit" style="margin-bottom: 1.5rem;">Uso da Assinatura</h3>
                <div style="margin-bottom: 2rem;">
                    <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                        <span>Uso de Mensagens</span>
                        <span style="font-weight: 700;">@billingInfo.CurrentUsage.ToString("N0") / @billingInfo.MessageLimit.ToString("N0")</span>
                    </div>
                    <div style="height: 12px; background: rgba(255,255,255,0.1); border-radius: 10px; overflow: hidden;">
                        <div style="width: @(Math.Min(100, (double)billingInfo.CurrentUsage / billingInfo.MessageLimit * 100))%; height: 100%; background: linear-gradient(90deg, var(--primary), var(--accent));"></div>
                    </div>
                </div>

                <h3 class="outfit" style="margin-bottom: 1.5rem;">Faturas Recentes</h3>
                <table style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="text-align: left; border-bottom: 1px solid var(--border); color: var(--text-muted); font-size: 0.9rem;">
                            <th style="padding: 1rem;">Data</th>
                            <th style="padding: 1rem;">Valor</th>
                            <th style="padding: 1rem;">Status</th>
                            <th style="padding: 1rem;">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr style="border-bottom: 1px solid var(--border);">
                            <td style="padding: 1.25rem;">01 Dez, 2025</td>
                            <td style="padding: 1.25rem; font-weight: 600;">R$ @billingInfo.Price.ToString("N2")</td>
                            <td style="padding: 1.25rem;"><span style="color: #10b981; font-weight: 700;">Pago</span></td>
                            <td style="padding: 1.25rem;"><button style="color: var(--accent); background: none; border: none; font-weight: 600; cursor: pointer;">PDF</button></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
