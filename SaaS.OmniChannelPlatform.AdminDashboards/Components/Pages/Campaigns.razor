@page "/campaigns"
@inject ApiService ApiService

@code {
    private List<CampaignModel> campaigns = new();

    protected override async Task OnInitializedAsync()
    {
        campaigns = await ApiService.GetCampaignsAsync();
    }
}

<PageTitle>Campanhas | OmniSaaS</PageTitle>

<div class="animate-fade">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2.5rem;">
        <div>
            <h1 class="outfit" style="font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem;">Gestão de Campanhas</h1>
            <p style="color: var(--text-muted);">Crie e monitore seus disparos em massa.</p>
        </div>
        <button class="btn-primary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Nova Campanha
        </button>
    </div>

    <div class="card">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="text-align: left; border-bottom: 1px solid var(--border); color: var(--text-muted);">
                    <th style="padding: 1rem;">Nome</th>
                    <th style="padding: 1rem;">Status</th>
                    <th style="padding: 1rem;">Progresso</th>
                    <th style="padding: 1rem;">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var campaign in campaigns)
                {
                    <tr style="border-bottom: 1px solid var(--border);">
                        <td style="padding: 1.5rem;">@campaign.Name</td>
                        <td style="padding: 1.5rem;">
                            @if (campaign.Status == "Running")
                            {
                                <span style="background: rgba(16, 185, 129, 0.2); color: #10b981; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.85rem;">Enviando</span>
                            }
                            else
                            {
                                <span style="background: rgba(99, 102, 241, 0.2); color: var(--primary); padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.85rem;">@campaign.Status</span>
                            }
                        </td>
                        <td style="padding: 1.5rem;">
                            @if (campaign.Progress > 0)
                            {
                                <div style="width: 100px; height: 6px; background: rgba(255,255,255,0.1); border-radius: 10px;">
                                    <div style="width: @(campaign.Progress)%; height: 100%; background: var(--accent); border-radius: 10px;"></div>
                                </div>
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </td>
                        <td style="padding: 1.5rem;">
                            <button style="background: none; border: none; color: var(--text-muted); cursor: pointer;"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="1"></circle><circle cx="12" cy="5" r="1"></circle><circle cx="12" cy="19" r="1"></circle></svg></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
