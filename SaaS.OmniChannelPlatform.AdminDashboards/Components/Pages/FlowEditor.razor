@page "/flows/edit/{Id:guid?}"
@inject ApiService ApiService
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components.Web
@implements IDisposable

@code {
    [Parameter] public Guid? Id { get; set; }
    private FlowModel _flow = new() 
    { 
        Name = "Novo Agente OmniChannel", 
        Steps = new List<FlowStepModel> { new() { Title = "Início", Type = "Starter", X = 50, Y = 50, NodeCategory = "Trigger" } }
    };

    private FlowStepModel? _activeNode;
    private double _offsetX, _offsetY;
    private double _mouseX, _mouseY;
    private FlowStepModel? _connectingFrom;
    private string _connectingPort = "Success"; // "Success" or "Fallback"
    private FlowStepModel? _selectedNode;

    private List<ChannelConnectionModel> _connections = new();
    private bool _showConnectionsModal = false;

    protected override async Task OnInitializedAsync()
    {
        _connections = await ApiService.GetChannelsAsync();

        if (Id.HasValue)
        {
            var flows = await ApiService.GetFlowsAsync();
            var found = flows.FirstOrDefault(f => f.Id == Id.Value);
            if (found != null) _flow = found;
        }

        if (_connections.Any(c => c.Platform == "WhatsApp" && c.Status != "Connected"))
        {
            StartQrPolling();
        }
    }

    private void AddStep(string type, string category)
    {
        var title = GetTitle(type);
        var step = new FlowStepModel
        {
            Type = type,
            Title = title,
            NodeCategory = category,
            X = 300,
            Y = 150
        };
        
        // Initialize metadata if needed
        if (type == "LLMProcessor")
        {
            step.Metadata["Provider"] = "Google";
            step.Metadata["Model"] = "gemini-1.5-flash";
        }
        
        if (category == "Trigger")
        {
            step.Metadata["ConnectionId"] = string.Empty;
        }

        _flow.Steps.Add(step);
    }

    private string GetTitle(string type) => type switch {
        "WhatsAppTrigger" => "WhatsApp (Input)",
        "TelegramTrigger" => "Telegram (Input)",
        "InstagramTrigger" => "Instagram (Input)",
        "LLMProcessor" => "Cérebro IA (LLM)",
        "InternalModel" => "Modelo Interno (NLP)",
        "WhatsAppOutput" => "Resposta WhatsApp",
        "TelegramOutput" => "Resposta Telegram",
        "InstagramOutput" => "Resposta Instagram",
        "Condition" => "Decisão (IF/Else)",
        "Integration" => "API Externa",
        _ => type
    };

    private void HandleMouseDown(MouseEventArgs e, FlowStepModel node)
    {
        _selectedNode = node;
        _activeNode = node;
        _offsetX = e.ClientX - node.X;
        _offsetY = e.ClientY - node.Y;
    }

    private void HandleMouseMove(MouseEventArgs e)
    {
        _mouseX = e.ClientX;
        _mouseY = e.ClientY;
        
        if (_activeNode != null)
        {
            _activeNode.X = e.ClientX - _offsetX;
            _activeNode.Y = e.ClientY - _offsetY;
        }
    }

    private void HandleMouseUp()
    {
        _activeNode = null;
    }

    private void StartConnection(FlowStepModel step, string port = "Success")
    {
        _connectingFrom = step;
        _connectingPort = port;
    }

    private void CompleteConnection(FlowStepModel toStep)
    {
        if (_connectingFrom != null && _connectingFrom.Id != toStep.Id)
        {
            if (_connectingPort == "Success")
                _connectingFrom.NextStepId = toStep.Id;
            else
                _connectingFrom.FallbackStepId = toStep.Id;

            _connectingFrom = null;
        }
    }

    private void RemoveStep(Guid id)
    {
        var step = _flow.Steps.FirstOrDefault(s => s.Id == id);
        if (step != null && step.Type != "Starter") _flow.Steps.Remove(step);
    }

    private async Task HandleChannelSelection(FlowStepModel step, string? connId)
    {
        step.Metadata["ConnectionId"] = connId ?? "";
        if (!string.IsNullOrEmpty(connId))
        {
            var conn = _connections.FirstOrDefault(c => c.Id.ToString() == connId);
            if (conn != null && (conn.Status == "Disconnected" || conn.Status == "Pending"))
            {
                await ApiService.RefreshChannelQRAsync(conn);
                StartQrPolling();
                StateHasChanged();
            }
        }
    }

    private System.Threading.Timer? _qrTimer;

    private void StartQrPolling()
    {
        if (_qrTimer == null)
        {
            _qrTimer = new System.Threading.Timer(async _ =>
            {
                try
                {
                    var pendingConns = _connections.Where(c => c.Platform == "WhatsApp" && c.Status != "Connected").ToList();
                    if (!pendingConns.Any())
                    {
                        StopQrPolling();
                        return;
                    }

                    foreach (var conn in pendingConns)
                    {
                        await ApiService.RefreshChannelQRAsync(conn);
                        if (conn.Status == "Connected") 
                        {
                            if (!_connections.Any(c => c.Platform == "WhatsApp" && c.Status != "Connected"))
                            {
                                StopQrPolling();
                            }
                        }
                    }
                    await InvokeAsync(StateHasChanged);
                }
                catch { /* Silent fail for timer background work */ }
            }, null, 3000, 3000);
        }
    }

    private void StopQrPolling()
    {
        _qrTimer?.Dispose();
        _qrTimer = null;
    }

    public void Dispose() => StopQrPolling();

    private void ClearConnection(FlowStepModel step, string port = "Success") 
    {
        if (port == "Success") step.NextStepId = null;
        else step.FallbackStepId = null;
    }

    private async Task SaveFlow()
    {
        await Task.Delay(500);
        Navigation.NavigateTo("/flows");
    }
}

<PageTitle>Editor de Agente OmniSaaS</PageTitle>

<div class="flow-layout">
    <!-- Header -->
    <header class="flow-header">
        <div class="header-left">
            <button @onclick='() => Navigation.NavigateTo("/flows")' class="btn-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            </button>
            <div class="header-info">
                <h1 class="outfit">@_flow.Name</h1>
                <span class="status-indicator">Editor Visual - Beta</span>
            </div>
        </div>
        <div class="header-actions">
            <button class="btn-outline" @onclick="() => _showConnectionsModal = true">Conexões</button>
            <button class="btn-primary" @onclick="SaveFlow">Salvar Agente</button>
        </div>
    </header>

    <div class="flow-workspace">
        <!-- Sidebar: Node Library -->
        <aside class="node-sidebar">
            <div class="sidebar-header">
                <input type="text" placeholder="Buscar nós..." class="search-input" />
            </div>
            
            <div class="node-groups">
                <div class="node-group">
                    <label>Triggers (Entrada)</label>
                    <div class="sidebar-item trigger" @onclick='() => AddStep("WhatsAppTrigger", "Trigger")'>
                        <span class="icon">W</span> WhatsApp
                    </div>
                    <div class="sidebar-item trigger" @onclick='() => AddStep("TelegramTrigger", "Trigger")'>
                        <span class="icon">T</span> Telegram
                    </div>
                </div>

                <div class="node-group">
                    <label>Inteligência (IA)</label>
                    <div class="sidebar-item process" @onclick='() => AddStep("LLMProcessor", "Process")'>
                        <span class="icon">AI</span> Cérebro LLM
                    </div>
                    <div class="sidebar-item process" @onclick='() => AddStep("InternalModel", "Process")'>
                        <span class="icon">M</span> Modelo Core
                    </div>
                    <div class="sidebar-item process" @onclick='() => AddStep("Condition", "Process")'>
                        <span class="icon">?</span> Condição IF
                    </div>
                </div>

                <div class="node-group">
                    <label>Ações (Saída)</label>
                    <div class="sidebar-item output" @onclick='() => AddStep("WhatsAppOutput", "Output")'>
                        <span class="icon">S</span> Resposta WhatsApp
                    </div>
                    <div class="sidebar-item output" @onclick='() => AddStep("TelegramOutput", "Output")'>
                        <span class="icon">S</span> Resposta Telegram
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Canvas -->
        <main class="canvas-area" @onmousemove="HandleMouseMove" @onmouseup="HandleMouseUp">
            <div class="canvas-grid"></div>
            
            <svg class="line-svg">
                <!-- Existing Connections -->
                @foreach (var step in _flow.Steps.Where(s => s.NextStepId.HasValue))
                {
                    var target = _flow.Steps.FirstOrDefault(s => s.Id == step.NextStepId.Value);
                    if (target != null)
                    {
                        var startX = step.X + 200;
                        var startY = step.Y + 40;
                        var endX = target.X;
                        var endY = target.Y + 40;
                        
                        var controlOffset = Math.Max(50, Math.Abs(endX - startX) / 2);
                        <path d="M @startX @startY C @(startX + controlOffset) @startY, @(endX - controlOffset) @endY, @endX @endY" 
                               stroke="var(--accent)" stroke-width="2.5" fill="none" class="connection-line" />
                    }

                    if (step.FallbackStepId.HasValue)
                    {
                        var fallbackTarget = _flow.Steps.FirstOrDefault(s => s.Id == step.FallbackStepId.Value);
                        if (fallbackTarget != null)
                        {
                            var startX = step.X + 200;
                            var startY = step.Y + 65; // Lower port
                            var endX = fallbackTarget.X;
                            var endY = fallbackTarget.Y + 40;
                            
                            var controlOffset = Math.Max(50, Math.Abs(endX - startX) / 2);
                            <path d="M @startX @startY C @(startX + controlOffset) @startY, @(endX - controlOffset) @endY, @endX @endY" 
                                   stroke="#ef4444" stroke-width="2.5" fill="none" class="connection-line" opacity="0.6" />
                        }
                    }
                }

                <!-- Connection Preview (Ghost Line) -->
                @if (_connectingFrom != null)
                {
                    var startX = _connectingFrom.X + 200;
                    var startY = _connectingFrom.Y + 40;
                    
                    // Note: This is an approximation since mouse coords are viewport-relative
                    // In a production app, we'd use GetBoundingClientRect to get canvas offset
                    // For now, we'll assume the canvas takes up most of the screen
                    var canvasOffsetLeft = 260 + 24; // Sidebar + gap
                    var canvasOffsetTop = 64 + 24;  // Header + gap
                    
                    var endX = _mouseX - canvasOffsetLeft - 32; 
                    var endY = _mouseY - canvasOffsetTop - 32;

                    var controlOffset = Math.Max(50, Math.Abs(endX - startX) / 2);
                    <path d="M @startX @startY C @(startX + controlOffset) @startY, @(endX - controlOffset) @endY, @endX @endY" 
                          stroke="white" stroke-width="2" stroke-dasharray="5,5" fill="none" opacity="0.5" />
                }
            </svg>

            @foreach (var step in _flow.Steps)
            {
                <div class="n8n-node @(step.NodeCategory.ToLower()) @(_selectedNode?.Id == step.Id ? "selected" : "") @(_connectingFrom?.Id == step.Id ? "connecting" : "")" 
                     style="left: @(step.X)px; top: @(step.Y)px;"
                     @onmousedown="(e) => HandleMouseDown(e, step)"
                     @onmousedown:stopPropagation="true"
                     @onclick:stopPropagation="true"
                     @onclick="() => CompleteConnection(step)">
                    
                    <div class="node-icon">
                        @if (step.Title.Contains("WhatsApp")) { <span class="wa-icon">WP</span> }
                        else if (step.Title.Contains("Cérebro")) { <span class="ai-icon">✨</span> }
                        else if (step.Title.Contains("Início")) { <span class="start-icon">▶</span> }
                        else { <span>@step.Title.Substring(0, 1)</span> }
                    </div>
                    
                    <div class="node-content">
                        <div class="node-label">@step.Title</div>
                        <div class="node-sublabel">@step.Type</div>
                    </div>

                    @if (step.NodeCategory != "Trigger")
                    {
                        <div class="port input" @onclick="() => CompleteConnection(step)"></div>
                    }

                    <div class="port output" @onclick="() => StartConnection(step)"></div>

                    @if (step.Type == "InternalModel")
                    {
                        <div class="port output fallback" @onclick='() => StartConnection(step, "Fallback")' title="Se não encontrar no CSV"></div>
                    }

                    @if (_selectedNode?.Id == step.Id && step.Type != "Starter")
                    {
                        <button class="node-delete" @onclick="() => RemoveStep(step.Id)">×</button>
                    }
                </div>
            }
        </main>

        <!-- Right Panel: Properties -->
        @if (_selectedNode != null)
        {
            <aside class="properties-sidebar">
                <div class="panel-header">
                    <h3>Configuração: @_selectedNode.Title</h3>
                    <button @onclick="() => _selectedNode = null" class="close">×</button>
                </div>
                
                <div class="panel-body">
                    @if (_selectedNode.NodeCategory == "Trigger" && _selectedNode.Type != "Starter")
                    {
                        var connId = _selectedNode.Metadata.ContainsKey("ConnectionId") ? _selectedNode.Metadata["ConnectionId"] : "";
                        var currentConn = _connections.FirstOrDefault(c => c.Id.ToString() == connId);

                        <div class="field-item">
                            <label>Canal do WhatsApp</label>
                            <select @onchange='(e) => HandleChannelSelection(_selectedNode, e.Value?.ToString())' value="@connId" class="panel-select">
                                <option value="">-- Selecione --</option>
                                @foreach (var conn in _connections.Where(c => _selectedNode.Type.Contains(c.Platform)))
                                {
                                    <option value="@conn.Id">@conn.Name (@conn.Status)</option>
                                }
                            </select>
                        </div>

                        @if (currentConn != null && currentConn.Status != "Connected")
                        {
                            <div class="panel-qr-card">
                                @if (!string.IsNullOrEmpty(currentConn.QRCodeBase64))
                                {
                                    <img src="@currentConn.QRCodeBase64" />
                                }
                                else
                                {
                                    <div class="loader-box"><div class="status-pulse"></div></div>
                                }
                                <span>Aguardando Scan...</span>
                            </div>
                        }
                    }

                    <div class="field-item">
                        <label>Instruções do Sistema (Prompt)</label>
                        <textarea @bind="_selectedNode.Content" placeholder="Ex: Você é um assistente de vendas especializado em..."></textarea>
                    </div>

                    @if (_selectedNode.Type == "LLMProcessor")
                    {
                        var provider = _selectedNode.Metadata.ContainsKey("Provider") ? _selectedNode.Metadata["Provider"] : "Google";
                        var model = _selectedNode.Metadata.ContainsKey("Model") ? _selectedNode.Metadata["Model"] : "gemini-1.5-flash";

                        <div class="field-item">
                            <label>Provedor de IA</label>
                            <select @onchange='(e) => { _selectedNode.Metadata["Provider"] = e.Value?.ToString() ?? ""; StateHasChanged(); }' value="@provider" class="panel-select">
                                <option value="Google">Google (Gemini)</option>
                                <option value="OpenAI">OpenAI (ChatGPT)</option>
                            </select>
                        </div>

                        <div class="field-item">
                            <label>Modelo</label>
                            <select @onchange='(e) => _selectedNode.Metadata["Model"] = e.Value?.ToString() ?? ""' value="@model" class="panel-select">
                                @if (provider == "Google")
                                {
                                    <option value="gemini-1.5-flash">Gemini 1.5 Flash</option>
                                    <option value="gemini-1.5-flash-8b">Gemini 1.5 Flash-8B</option>
                                    <option value="gemini-1.5-pro">Gemini 1.5 Pro</option>
                                    <option value="gemini-2.0-flash-exp">Gemini 2.0 Flash</option>
                                    <option value="gemini-2.0-pro-exp">Gemini 2.0 Pro</option>
                                }
                                else
                                {
                                    <option value="gpt-3.5-turbo">GPT-3.5 Turbo</option>
                                    <option value="gpt-4">GPT-4</option>
                                    <option value="gpt-4-turbo">GPT-4 Turbo</option>
                                    <option value="gpt-4o">GPT-4o</option>
                                    <option value="gpt-4o-mini">GPT-4o mini</option>
                                }
                            </select>
                        </div>

                        <div class="field-item">
                            <label>Base de Conhecimento Secundária (RAG)</label>
                            <div class="knowledge-upload">
                                <input type="file" id="kbUpload" accept=".txt,.csv,.pdf" hidden />
                                <label for="kbUpload" class="btn-outline" style="width: 100%; display: block; text-align: center; border-style: dashed;">
                                    📁 Anexar TXT, CSV ou PDF
                                </label>
                                @if (_selectedNode.Metadata.ContainsKey("KbFileName"))
                                {
                                    <div class="file-info success">
                                        <span>📄 @_selectedNode.Metadata["KbFileName"]</span>
                                        <button @onclick='() => _selectedNode.Metadata.Remove("KbFileName")' class="close">×</button>
                                    </div>
                                }
                            </div>
                            <p class="field-help">O conteúdo deste arquivo será usado como contexto adicional para as respostas da IA.</p>
                        </div>
                    }

                    @if (_selectedNode.Type == "InternalModel")
                    {
                        <div class="field-item">
                            <label>Base de Conhecimento (CSV)</label>
                            <div class="csv-upload-box">
                                <input type="file" id="csvUpload" hidden />
                                <label for="csvUpload" class="btn-outline" style="width: 100%; display: block; text-align: center;">
                                    📤 Upload CSV (Perguntas/Respostas)
                                </label>
                                @if (_selectedNode.Metadata.ContainsKey("CSVFileName"))
                                {
                                    <span class="file-tag">@_selectedNode.Metadata["CSVFileName"]</span>
                                }
                            </div>
                            <p class="field-help">Se a entrada bater com uma linha do CSV, segue pelo caminho "Encontrado". Caso contrário, segue pelo "Fallback".</p>
                        </div>
                    }

                    @if (_selectedNode.NextStepId != null)
                    {
                        <div class="connection-status success">
                            <span>✔ Conectado (Sucesso)</span>
                            <button @onclick='() => ClearConnection(_selectedNode, "Success")'>×</button>
                        </div>
                    }

                    @if (_selectedNode.FallbackStepId != null)
                    {
                        <div class="connection-status error">
                            <span>✖ Conectado (Fallback)</span>
                            <button @onclick='() => ClearConnection(_selectedNode, "Fallback")'>×</button>
                        </div>
                    }
                </div>
            </aside>
        }
    </div>
</div>

@if (_showConnectionsModal)
{
    <div class="modal-backdrop" @onclick="() => _showConnectionsModal = false">
        <div class="modal-card card" @onclick:stopPropagation="true">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <h2 class="outfit" style="margin: 0; font-weight: 800;">Conectar Nova Conta</h2>
                <button @onclick="() => _showConnectionsModal = false" class="close">×</button>
            </div>
            
            <div style="display: grid; gap: 1.2rem;">
                @foreach (var conn in _connections)
                {
                    <div class="connection-item @(conn.Status == "Connected" ? "active" : "")">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: 700; font-size: 1rem;">@conn.Name</div>
                                <div style="font-size: 0.75rem; color: var(--text-muted);">@conn.Platform • @conn.AccountIdentifier</div>
                            </div>
                            <div class="status-badge @(conn.Status.ToLower())">
                                @conn.Status.ToUpper()
                            </div>
                        </div>

                        @if (conn.Status == "Pending" || conn.Status == "Disconnected")
                        {
                            <div style="text-align: center; background: white; padding: 1.5rem; border-radius: 12px; margin-bottom: 1rem;">
                                @if (!string.IsNullOrEmpty(conn.QRCodeBase64))
                                {
                                    <img src="@conn.QRCodeBase64" style="width: 150px; height: 150px; border: 4px solid #fff;" />
                                }
                                else
                                {
                                    <div style="width: 150px; height: 150px; margin: 0 auto; display: flex; align-items: center; justify-content: center; background: #000; border: 4px solid #fff;">
                                        <div class="status-pulse" style="width: 40px; height: 40px;"></div>
                                        <p style="position: absolute; font-size: 0.6rem; color: #fff; margin-top: 60px;">AGUARDANDO...</p>
                                    </div>
                                }
                                <p style="color: #000; font-size: 0.7rem; font-weight: 700; margin-top: 1rem;">ESCANEIE O QR CODE NO @conn.Platform.ToUpper()</p>
                            </div>
                            <button class="btn-primary" style="width: 100%; border-radius: 8px;" @onclick='() => conn.Status = "Connected"'>Confirmar Conexão</button>
                        }
                        else
                        {
                            <div style="display: flex; gap: 0.5rem; font-size: 0.7rem; color: #10b981; font-weight: 600;">
                                <span>✔ Sessão Ativa</span>
                                <span style="color: var(--text-muted);">|</span>
                                <span>Token: @(conn.SessionToken?.Substring(0, 10))...</span>
                            </div>
                        }
                    </div>
                }
                
                <button class="btn-primary" style="margin-top: 0.5rem; width: 100%; background: var(--glass); border: 2px dashed var(--accent);">
                    + Novo Canal de Atendimento
                </button>
            </div>
        </div>
    </div>
}

<style>
    /* layout */
    .flow-layout { display: flex; flex-direction: column; height: 100vh; background: #0b0e11; color: #f8fafc; font-family: 'Inter', sans-serif; overflow: hidden; }
    .flow-header { height: 64px; background: #161a21; border-bottom: 1px solid #2d3643; display: flex; align-items: center; justify-content: space-between; padding: 0 1.5rem; flex-shrink: 0; box-shadow: 0 4px 20px rgba(0,0,0,0.3); z-index: 200; }
    .header-left { display: flex; align-items: center; gap: 1rem; }
    .header-info h1 { font-size: 1.1rem; font-weight: 800; margin: 0; color: white; letter-spacing: -0.5px; }
    .status-indicator { font-size: 0.65rem; color: #64748b; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }
    .header-actions { display: flex; gap: 0.75rem; }

    .flow-workspace { display: flex; flex: 1; overflow: hidden; position: relative; }

    /* Node Sidebar */
    .node-sidebar { width: 260px; background: #161a21; border-right: 1px solid #2d3643; display: flex; flex-direction: column; flex-shrink: 0; z-index: 100; }
    .sidebar-header { padding: 1.2rem; border-bottom: 1px solid #2d3643; }
    .search-input { width: 100%; background: #0f1115; border: 1px solid #2d3643; border-radius: 8px; padding: 0.6rem 0.8rem; color: white; font-size: 0.8rem; outline: none; transition: 0.2s; }
    .search-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(59,130,246,0.2); }

    .node-groups { flex: 1; overflow-y: auto; padding: 1.2rem; display: flex; flex-direction: column; gap: 1.5rem; }
    .node-group label { display: block; font-size: 0.65rem; font-weight: 800; color: #64748b; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.8rem; }
    
    .sidebar-item { background: #0f1115; border: 1px solid #2d3643; border-radius: 10px; padding: 0.75rem; display: flex; align-items: center; gap: 0.8rem; font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: 0.2s; margin-bottom: 0.5rem; }
    .sidebar-item:hover { transform: translateX(5px); border-color: #3b82f6; background: #1c232d; }
    .sidebar-item .icon { width: 32px; height: 32px; border-radius: 6px; background: #1c232d; display: flex; align-items: center; justify-content: center; font-size: 0.7rem; font-weight: 800; border: 1px solid #2d3643; }
    .sidebar-item.trigger .icon { color: #f59e0b; border-bottom: 2px solid #f59e0b; }
    .sidebar-item.process .icon { color: #a855f7; border-bottom: 2px solid #a855f7; }
    .sidebar-item.output .icon { color: #10b981; border-bottom: 2px solid #10b981; }

    /* Canvas Area ref*/
    .canvas-area { flex: 1; position: relative; background: #13171e; overflow: hidden; cursor: crosshair; }
    .canvas-grid { position: absolute; inset: 0; background-image: radial-gradient(#2d3643 1px, transparent 1px); background-size: 24px 24px; pointer-events: none; }
