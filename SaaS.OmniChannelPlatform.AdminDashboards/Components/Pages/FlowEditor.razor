@page "/flows/edit/{Id:guid?}"
@inject ApiService ApiService
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components.Web
@implements IDisposable

@code {
    [Parameter] public Guid? Id { get; set; }
    private FlowModel _flow = new() 
    { 
        Name = "Novo Agente OmniChannel", 
        Steps = new List<FlowStepModel> { new() { Title = "Início", Type = "Starter", X = 50, Y = 50, NodeCategory = "Trigger" } }
    };

    private FlowStepModel? _activeNode;
    private double _offsetX, _offsetY;
    private FlowStepModel? _connectingFrom;

    private List<ChannelConnectionModel> _connections = new();
    private bool _showConnectionsModal = false;

    protected override async Task OnInitializedAsync()
    {
        _connections = await ApiService.GetChannelsAsync();

        if (Id.HasValue)
        {
            var flows = await ApiService.GetFlowsAsync();
            var found = flows.FirstOrDefault(f => f.Id == Id.Value);
            if (found != null) _flow = found;
        }

        if (_connections.Any(c => c.Platform == "WhatsApp" && c.Status != "Connected"))
        {
            StartQRPolling();
        }
    }

    private void AddStep(string type, string category)
    {
        var title = GetTitle(type);
        var step = new FlowStepModel
        {
            Type = type,
            Title = title,
            NodeCategory = category,
            X = 300,
            Y = 150
        };
        
        // Initialize metadata if needed
        if (category == "Trigger")
            step.Metadata["ConnectionId"] = string.Empty;

        _flow.Steps.Add(step);
    }

    private string GetTitle(string type) => type switch {
        "WhatsAppTrigger" => "WhatsApp (Input)",
        "TelegramTrigger" => "Telegram (Input)",
        "InstagramTrigger" => "Instagram (Input)",
        "LLMProcessor" => "Cérebro IA (LLM)",
        "InternalModel" => "Modelo Interno (NLP)",
        "WhatsAppOutput" => "Resposta WhatsApp",
        "TelegramOutput" => "Resposta Telegram",
        "InstagramOutput" => "Resposta Instagram",
        "Condition" => "Decisão (IF/Else)",
        "Integration" => "API Externa",
        _ => type
    };

    private void HandleMouseDown(MouseEventArgs e, FlowStepModel node)
    {
        _activeNode = node;
        _offsetX = e.ClientX - node.X;
        _offsetY = e.ClientY - node.Y;
    }

    private void HandleMouseMove(MouseEventArgs e)
    {
        if (_activeNode != null)
        {
            _activeNode.X = e.ClientX - _offsetX;
            _activeNode.Y = e.ClientY - _offsetY;
        }
    }

    private void HandleMouseUp()
    {
        _activeNode = null;
    }

    private void StartConnection(FlowStepModel step)
    {
        _connectingFrom = step;
    }

    private void CompleteConnection(FlowStepModel toStep)
    {
        if (_connectingFrom != null && _connectingFrom.Id != toStep.Id)
        {
            _connectingFrom.NextStepId = toStep.Id;
            _connectingFrom = null;
        }
    }

    private void RemoveStep(Guid id)
    {
        var step = _flow.Steps.FirstOrDefault(s => s.Id == id);
        if (step != null && step.Type != "Starter") _flow.Steps.Remove(step);
    }

    private async Task HandleChannelSelection(FlowStepModel step, string? connId)
    {
        step.Metadata["ConnectionId"] = connId ?? "";
        if (!string.IsNullOrEmpty(connId))
        {
            var conn = _connections.FirstOrDefault(c => c.Id.ToString() == connId);
            if (conn != null && (conn.Status == "Disconnected" || conn.Status == "Pending"))
            {
                await ApiService.RefreshChannelQRAsync(conn);
                StartQRPolling();
                StateHasChanged();
            }
        }
    }

    private System.Threading.Timer? _qrTimer;

    private void StartQRPolling()
    {
        if (_qrTimer == null)
        {
            _qrTimer = new System.Threading.Timer(async _ =>
            {
                try
                {
                    var pendingConns = _connections.Where(c => c.Platform == "WhatsApp" && c.Status != "Connected").ToList();
                    if (!pendingConns.Any())
                    {
                        StopQRPolling();
                        return;
                    }

                    foreach (var conn in pendingConns)
                    {
                        await ApiService.RefreshChannelQRAsync(conn);
                        if (conn.Status == "Connected") 
                        {
                            if (!_connections.Any(c => c.Platform == "WhatsApp" && c.Status != "Connected"))
                            {
                                StopQRPolling();
                            }
                        }
                    }
                    await InvokeAsync(StateHasChanged);
                }
                catch { /* Silent fail for timer background work */ }
            }, null, 3000, 3000);
        }
    }

    private void StopQRPolling()
    {
        _qrTimer?.Dispose();
        _qrTimer = null;
    }

    public void Dispose() => StopQRPolling();

    private void ClearConnection(FlowStepModel step) => step.NextStepId = null;

    private async Task SaveFlow()
    {
        await Task.Delay(500);
        Navigation.NavigateTo("/flows");
    }
}

<PageTitle>Editor de Agente OmniSaaS</PageTitle>

<div class="animate-fade" @onmousemove="HandleMouseMove" @onmouseup="HandleMouseUp">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <button @onclick='() => Navigation.NavigateTo("/flows")' class="back-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                Voltar
            </button>
            <h1 class="outfit" style="font-size: 1.8rem; font-weight: 800; margin: 0;">Construtor de Agente Multicanal</h1>
        </div>
        <button class="btn-primary" @onclick="SaveFlow">Salvar Agente</button>
    </div>

    <div style="display: grid; grid-template-columns: 280px 1fr; gap: 1.5rem; height: calc(100vh - 200px);">
        <!-- Sidebar -->
        <div class="card" style="display: flex; flex-direction: column; gap: 1.2rem; overflow-y: auto;">
            
            <section>
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
                    <h3 class="sidebar-label" style="color: var(--accent); margin: 0;">Entradas (Triggers)</h3>
                    <button @onclick="() => _showConnectionsModal = true" style="background: none; border: none; color: var(--accent); cursor: pointer; font-size: 0.7rem; font-weight: 700;">+ Gerenciar</button>
                </div>
                <div class="tool-item" @onclick='() => AddStep("WhatsAppTrigger", "Trigger")'>WhatsApp Input</div>
                <div class="tool-item" @onclick='() => AddStep("TelegramTrigger", "Trigger")'>Telegram Input</div>
                <div class="tool-item" @onclick='() => AddStep("InstagramTrigger", "Trigger")'>Instagram Input</div>
            </section>

            <section>
                <h3 class="sidebar-label" style="color: #a855f7;">Processamento (IA)</h3>
                <div class="tool-item" @onclick='() => AddStep("LLMProcessor", "Process")'>Cérebro LLM (OpenAI/Gemini)</div>
                <div class="tool-item" @onclick='() => AddStep("InternalModel", "Process")'>Modelo Interno Core</div>
                <div class="tool-item" @onclick='() => AddStep("Condition", "Process")'>Regra de Decisão IF</div>
            </section>

            <section>
                <h3 class="sidebar-label" style="color: #10b981;">Saídas (Respostas)</h3>
                <div class="tool-item" @onclick='() => AddStep("WhatsAppOutput", "Output")'>Enviar para WhatsApp</div>
                <div class="tool-item" @onclick='() => AddStep("TelegramOutput", "Output")'>Enviar para Telegram</div>
                <div class="tool-item" @onclick='() => AddStep("InstagramOutput", "Output")'>Enviar para Instagram</div>
            </section>

            <div style="margin-top: auto; padding: 1rem; background: rgba(var(--accent-rgb), 0.05); border-radius: 12px; border: 1px solid var(--border);">
                <p style="font-size: 0.7rem; color: var(--text-muted); line-height: 1.4;">
                    <strong>Design do Fluxo:</strong><br/>
                    1. Escolha a origem (Entrada)<br/>
                    2. Conecte ao Cérebro IA<br/>
                    3. Conecte à Saída correspondente
                </p>
            </div>
        </div>

        <!-- Canvas -->
        <div class="canvas">
            <div class="grid-bg"></div>
            
            <svg class="line-svg">
                @foreach (var step in _flow.Steps.Where(s => s.NextStepId.HasValue))
                {
                    var target = _flow.Steps.FirstOrDefault(s => s.Id == step.NextStepId.Value);
                    if (target != null)
                    {
                        var startX = step.X + 110;
                        var startY = step.Y + 110;
                        var endX = target.X + 110;
                        var endY = target.Y;
                        
                        <path d="M @startX @startY C @startX @(startY + 60), @endX @(endY - 60), @endX @endY" 
                              stroke="var(--accent)" stroke-width="3" fill="none" opacity="0.6" />
                        <circle cx="@endX" cy="@endY" r="5" fill="var(--accent)" />
                    }
                }
            </svg>

            @foreach (var step in _flow.Steps)
            {
                <div class="node @(step.Type.ToLower()) @(step.NodeCategory.ToLower()) @(_connectingFrom?.Id == step.Id ? "connecting" : "")" 
                     style="left: @(step.X)px; top: @(step.Y)px;"
                     @onmousedown="(e) => HandleMouseDown(e, step)"
                     @onclick="() => CompleteConnection(step)">
                    
                    <div class="node-header">
                        <span class="type-tag">@step.NodeCategory</span>
                        @if (step.Type != "Starter")
                        {
                            <button @onclick="() => RemoveStep(step.Id)" @onmousedown:stopPropagation="true" class="close">×</button>
                        }
                    </div>
                    
                    <div class="node-body">
                        <div class="node-title">@step.Title</div>
                        
                        @if (step.NodeCategory == "Trigger" && step.Type != "Starter")
                        {
                            var connId = step.Metadata.ContainsKey("ConnectionId") ? step.Metadata["ConnectionId"] : "";
                            var currentConn = _connections.FirstOrDefault(c => c.Id.ToString() == connId);

                            <div class="node-field" style="margin-bottom: 0.75rem;">
                                <label style="font-size: 0.65rem; color: var(--text-muted); display: block; margin-bottom: 4px;">CONTA VINCULADA</label>
                                <select @onchange='(e) => HandleChannelSelection(step, e.Value?.ToString())' 
                                        value="@connId"
                                        @onmousedown:stopPropagation="true" class="node-select">
                                    <option value="">-- Selecione uma Conta --</option>
                                    @foreach (var conn in _connections.Where(c => step.Type.Contains(c.Platform)))
                                    {
                                        <option value="@conn.Id">@conn.Name (@conn.Status)</option>
                                    }
                                </select>
                            </div>

                            @if (currentConn == null || currentConn.Status != "Connected")
                            {
                                <div class="qr-container-mini" @onmousedown:stopPropagation="true">
                                    @if (!string.IsNullOrEmpty(currentConn?.QRCodeBase64))
                                    {
                                        <img src="@currentConn.QRCodeBase64" style="width: 80px; height: 80px; border: 2px solid white;" />
                                    }
                                    else
                                    {
                                        <div class="qr-code-mini"></div>
                                    }
                                    <span style="font-size: 0.6rem; color: #fff; font-weight: 800;">ESCANEIE PARA CONECTAR</span>
                                    <button class="btn-scan-mini" @onclick='() => { if(currentConn != null) currentConn.Status = "Connected"; }'>Simular Scan</button>
                                </div>
                            }
                            else
                            {
                                <div style="display: flex; align-items: center; gap: 5px; color: #10b981; font-size: 0.65rem; font-weight: 800; margin-bottom: 10px;">
                                    <span class="status-pulse"></span> CONECTADO EM @currentConn.Platform.ToUpper()
                                </div>
                            }
                        }

                        @if (step.NodeCategory == "Output")
                        {
                            <div style="background: rgba(16, 185, 129, 0.1); padding: 0.4rem; border-radius: 6px; font-size: 0.65rem; margin-bottom: 0.75rem; border: 1px solid rgba(16, 185, 129, 0.2);">
                                <span style="color: #10b981;">●</span> Resposta automática para o remetente original.
                            </div>
                        }

                        <textarea @bind="step.Content" placeholder="Prompt ou Configuração..." @onmousedown:stopPropagation="true"></textarea>
                    </div>

                    <!-- Ports -->
                    <div class="port output" @onclick:stopPropagation="true" @onmousedown:stopPropagation="true" @onclick="() => StartConnection(step)">
                        <div class="pulse"></div>
                    </div>

                    @if (step.NextStepId != null)
                    {
                        <div class="link-label" @onclick:stopPropagation="true" @onmousedown:stopPropagation="true" @onclick="() => ClearConnection(step)">
                            Fluxo Ativo <span>×</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@if (_showConnectionsModal)
{
    <div class="modal-backdrop" @onclick="() => _showConnectionsModal = false">
        <div class="modal-card card" @onclick:stopPropagation="true">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <h2 class="outfit" style="margin: 0; font-weight: 800;">Conectar Nova Conta</h2>
                <button @onclick="() => _showConnectionsModal = false" class="close">×</button>
            </div>
            
            <div style="display: grid; gap: 1.2rem;">
                @foreach (var conn in _connections)
                {
                    <div class="connection-item @(conn.Status == "Connected" ? "active" : "")">
                        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
                            <div>
                                <div style="font-weight: 700; font-size: 1rem;">@conn.Name</div>
                                <div style="font-size: 0.75rem; color: var(--text-muted);">@conn.Platform • @conn.AccountIdentifier</div>
                            </div>
                            <div class="status-badge @(conn.Status.ToLower())">
                                @conn.Status.ToUpper()
                            </div>
                        </div>

                        @if (conn.Status == "Pending" || conn.Status == "Disconnected")
                        {
                            <div style="text-align: center; background: white; padding: 1.5rem; border-radius: 12px; margin-bottom: 1rem;">
                                @if (!string.IsNullOrEmpty(conn.QRCodeBase64))
                                {
                                    <img src="@conn.QRCodeBase64" style="width: 150px; height: 150px; border: 4px solid #fff;" />
                                }
                                else
                                {
                                    <div style="width: 150px; height: 150px; margin: 0 auto; display: flex; align-items: center; justify-content: center; background: #000; border: 4px solid #fff;">
                                        <div class="status-pulse" style="width: 40px; height: 40px;"></div>
                                        <p style="position: absolute; font-size: 0.6rem; color: #fff; margin-top: 60px;">AGUARDANDO...</p>
                                    </div>
                                }
                                <p style="color: #000; font-size: 0.7rem; font-weight: 700; margin-top: 1rem;">ESCANEIE O QR CODE NO @conn.Platform.ToUpper()</p>
                            </div>
                            <button class="btn-primary" style="width: 100%; border-radius: 8px;" @onclick='() => conn.Status = "Connected"'>Confirmar Conexão</button>
                        }
                        else
                        {
                            <div style="display: flex; gap: 0.5rem; font-size: 0.7rem; color: #10b981; font-weight: 600;">
                                <span>✔ Sessão Ativa</span>
                                <span style="color: var(--text-muted);">|</span>
                                <span>Token: @(conn.SessionToken?.Substring(0, 10))...</span>
                            </div>
                        }
                    </div>
                }
                
                <button class="btn-primary" style="margin-top: 0.5rem; width: 100%; background: var(--glass); border: 2px dashed var(--accent);">
                    + Novo Canal de Atendimento
                </button>
            </div>
        </div>
    </div>
}

<style>
    .node-select { width: 100%; background: #000; border: 1px solid var(--border); color: white; border-radius: 6px; padding: 0.4rem; font-size: 0.75rem; outline: none; margin-top: 5px; }
    .modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,0.8); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; z-index: 1000; }
    .modal-card { width: 450px; padding: 2rem; border: 2px solid var(--accent); max-height: 80vh; overflow-y: auto; }
    
    .connection-item { background: rgba(255,255,255,0.03); border: 1px solid var(--border); padding: 1.2rem; border-radius: 12px; transition: 0.3s; }
    .connection-item.active { border-color: #10b98166; background: rgba(16, 185, 129, 0.05); }
    
    .status-badge { padding: 0.2rem 0.6rem; border-radius: 20px; font-size: 0.65rem; font-weight: 800; letter-spacing: 0.5px; }
    .status-badge.connected { background: #10b98133; color: #10b981; }
    .status-badge.pending { background: #f59e0b33; color: #f59e0b; }
    .status-badge.disconnected { background: #ef444433; color: #ef4444; }

    .back-link { background: none; border: none; color: var(--accent); cursor: pointer; display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; font-weight: 600; }
    
    .qr-container-mini { background: #1a1a1e; border: 1px solid var(--border); border-radius: 8px; padding: 10px; text-align: center; margin-bottom: 15px; display: flex; flex-direction: column; align-items: center; gap: 8px; }
    .qr-code-mini { width: 80px; height: 80px; background: repeating-conic-gradient(#000 0% 25%, #fff 0% 50%) 50% / 10px 10px; border: 2px solid white; }
    .btn-scan-mini { background: var(--accent); border: none; color: black; font-size: 0.6rem; font-weight: 900; padding: 4px 10px; border-radius: 4px; cursor: pointer; text-transform: uppercase; }
    
    .status-pulse { width: 8px; height: 8px; background: #10b981; border-radius: 50%; display: inline-block; position: relative; }
    .status-pulse::after { content: ""; position: absolute; inset: -3px; border: 2px solid #10b981; border-radius: 50%; animation: pulse-anim 1.5s infinite; }
    
    .sidebar-label { font-size: 0.75rem; font-weight: 900; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.75rem; display: block; }
    
    .tool-item { background: var(--glass); border: 1px solid var(--border); padding: 0.75rem; border-radius: 10px; cursor: pointer; transition: 0.25s; font-size: 0.8rem; font-weight: 600; margin-bottom: 0.5rem; }
    .tool-item:hover { background: var(--primary-glow); border-color: var(--primary); transform: translateX(5px); }

    .canvas { position: relative; background: #08080a; border-radius: 16px; border: 1px solid var(--border); overflow: hidden; height: 100%; box-shadow: inset 0 0 50px rgba(0,0,0,0.5); }
    .grid-bg { position: absolute; inset: 0; background-image: radial-gradient(rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 30px 30px; }

    .node { position: absolute; width: 220px; background: #121216; border: 1px solid var(--border); border-radius: 14px; z-index: 10; cursor: move; transition: border-color 0.2s, box-shadow 0.2s; user-select: none; }
    .node:hover { border-color: rgba(255,255,255,0.3); box-shadow: 0 10px 40px rgba(0,0,0,0.6); }
    .node.connecting { border-color: var(--accent); box-shadow: 0 0 30px var(--accent-glow); transform: scale(1.02); }
    
    .node-header { padding: 0.5rem 0.75rem; display: flex; justify-content: space-between; align-items: center; background: rgba(255,255,255,0.02); border-radius: 14px 14px 0 0; }
    .type-tag { font-size: 0.55rem; font-weight: 900; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.2px; }
    
    .node.trigger { border-left: 4px solid var(--accent); }
    .node.process { border-left: 4px solid #a855f7; }
    .node.output { border-left: 4px solid #10b981; }

    .close { background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 1rem; padding: 0; line-height: 1; transition: 0.2s; }
    .close:hover { color: #ef4444; }

    .node-body { padding: 0.75rem 1rem; }
    .node-title { font-weight: 700; font-size: 0.85rem; margin-bottom: 0.75rem; color: white; }
    .node-body textarea { width: 100%; background: rgba(0,0,0,0.3); border: 1px solid var(--border); border-radius: 8px; color: #fff; font-size: 0.75rem; padding: 0.6rem; resize: none; outline: none; height: 60px; }

    .port { position: absolute; width: 18px; height: 18px; background: var(--accent); border: 4px solid #121216; border-radius: 50%; cursor: crosshair; bottom: -9px; left: 50%; transform: translateX(-50%); z-index: 20; }
    .pulse { position: absolute; inset: -4px; border: 2px solid var(--accent); border-radius: 50%; animation: pulse-anim 2s infinite; }
    
    @@keyframes pulse-anim {
        0% { transform: scale(1); opacity: 0.8; }
        100% { transform: scale(1.8); opacity: 0; }
    }

    .link-label { position: absolute; bottom: -30px; left: 50%; transform: translateX(-50%); font-size: 0.6rem; color: var(--accent); font-weight: 900; cursor: pointer; white-space: nowrap; background: rgba(var(--accent-rgb), 0.1); padding: 2px 10px; border-radius: 20px; border: 1px solid var(--accent); }

    .line-svg { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; }
</style>
