@page "/flows"
@inject ApiService ApiService
@inject NavigationManager Navigation

@code {
    private List<FlowModel> _flows = new();

    protected override async Task OnInitializedAsync()
    {
        _flows = await ApiService.GetFlowsAsync();
    }

    private void CreateFlow() => Navigation.NavigateTo("/flows/edit");
    private void EditFlow(Guid id) => Navigation.NavigateTo($"/flows/edit/{id}");
}

<PageTitle>Fluxos & Bot | OmniSaaS</PageTitle>

<div class="animate-fade">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2.5rem;">
        <div>
            <h1 class="outfit" style="font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem;">Fluxos de Atendimento</h1>
            <p style="color: var(--text-muted);">Configure a inteligência do seu bot e caminhos de conversação.</p>
        </div>
        <button class="btn-primary" @onclick="CreateFlow">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7L12 12L22 7L12 2Z"></path><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
            Criar Novo Fluxo
        </button>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
        @foreach (var flow in _flows)
        {
            <div class="card">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem;">
                    <div>
                        <h3 class="outfit">@flow.Name</h3>
                        <p style="font-size: 0.85rem; color: var(--text-muted);">ID: @flow.Id.ToString().Substring(0,8)...</p>
                    </div>
                    @if (flow.IsActive)
                    {
                        <div style="background: rgba(16, 185, 129, 0.2); color: #10b981; padding: 0.2rem 0.6rem; border-radius: 6px; font-size: 0.75rem; font-weight: 700;">ATIVO</div>
                    }
                    else
                    {
                        <div style="background: rgba(255, 255, 255, 0.1); color: var(--text-muted); padding: 0.2rem 0.6rem; border-radius: 6px; font-size: 0.75rem; font-weight: 700;">INATIVO</div>
                    }
                </div>
                <div style="margin-bottom: 2rem;">
                    <div style="display: flex; gap: 0.5rem; margin-bottom: 0.5rem; color: var(--text-muted); font-size: 0.85rem;">
                        <span>@flow.StepsCount Passos</span>
                        <span>•</span>
                        <span>@(flow.IsAIEnabled ? "IA Ativada" : "IA Desativada")</span>
                    </div>
                    <div style="font-size: 0.9rem;">Ultima edição: @flow.LastModified.ToString("g")</div>
                </div>
                <div style="display: flex; gap: 0.75rem;">
                    <button class="btn-primary" style="flex: 1; font-size: 0.85rem; padding: 0.5rem;" @onclick="() => EditFlow(flow.Id)">Editar</button>
                    <button style="flex: 1; font-size: 0.85rem; padding: 0.5rem; background: var(--glass); border: 1px solid var(--border); border-radius: 12px; color: var(--text-main); font-weight: 600; cursor: pointer;">
                        @(flow.IsActive ? "Pausar" : "Ativar")
                    </button>
                </div>
            </div>
        }

         <div class="card" @onclick="CreateFlow" style="display: flex; flex-direction: column; align-items: center; justify-content: center; border-style: dashed; background: none; cursor: pointer;">
            <div style="background: var(--glass); padding: 1rem; border-radius: 50%; margin-bottom: 1rem;">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            </div>
            <p style="color: var(--text-muted); font-weight: 600;">Criar fluxo do zero</p>
        </div>
    </div>
</div>
